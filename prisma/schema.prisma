// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// RBAC Enums
enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  MANAGE // Full control
}

enum PermissionResource {
  PRODUCTS
  INVENTORY
  ORDERS
  CUSTOMERS
  DISCOUNTS
  CATEGORIES
  ANALYTICS
  USERS
  SETTINGS
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Business Profile
  email   String?
  website String?
  taxId   String?
  taxRate Decimal @default(0)

  // Receipt Settings
  receiptHeader String?
  receiptFooter String?
  showLogo      Boolean @default(true)
  logoUrl       String?

  // POS Settings
  autoPrintReceipt Boolean @default(true)
  soundEffects     Boolean @default(true)
  barcodeScanner   String? // Scanner type/config

  // Localization Settings
  language   String @default("en")
  currency   String @default("IDR")
  timezone   String @default("Asia/Jakarta")
  dateFormat String @default("DD/MM/YYYY")
  timeFormat String @default("24h") // "12h" or "24h"

  users            User[]
  roles            UserRole[]
  products         Product[]
  categories       Category[]
  orders           Order[]
  units            Unit[]
  stockAdjustments StockAdjustment[]
  customers        Customer[]
  discounts        Discount[]
  auditLogs        AuditLog[]
}

model User {
  id          String     @id @default(cuid())
  clerkUserId String     @unique // Link to Clerk user
  email       String
  name        String?
  roleId      String?
  role        UserRole?  @relation(fields: [roleId], references: [id])
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  auditLogs   AuditLog[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
  @@index([clerkUserId])
}

model Unit {
  id           String        @id @default(cuid())
  name         String // e.g. Box
  abbreviation String // e.g. bx
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  productUnits ProductUnit[]
}

model Category {
  id       String  @id @default(cuid())
  name     String
  parentId String? // NULL for root categories
  tenantId String

  // Relations
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, parentId, tenantId]) // Unique name within same parent and tenant
  @@index([tenantId])
  @@index([parentId])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  minStock    Int     @default(10)
  categoryId  String?
  tenantId    String

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Base Unit (e.g. Pcs)
  baseUnitId String?
  // Conversions
  units      ProductUnit[]

  options  ProductOption[]
  variants ProductVariant[]

  @@index([name])
}

model ProductUnit {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation(fields: [productId], references: [id])
  unitId           String
  unit             Unit    @relation(fields: [unitId], references: [id])
  conversionFactor Float // e.g. 12 (1 Box = 12 Base Units)
}

model ProductOption {
  id        String               @id @default(cuid())
  name      String // e.g. Size, Color
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]
}

model ProductOptionValue {
  id       String        @id @default(cuid())
  value    String // e.g. S, Red
  optionId String
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  variants ProductVariant[] // Implicit many-to-many or explicit? Implicit is fine for now.
}

model ProductVariant {
  id        String  @id @default(cuid())
  sku       String  @unique
  barcode   String? @unique // Specific barcode for this variant
  price     Decimal
  stock     Int     @default(0) // Stock in Base Unit
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // The combination of values that make up this variant
  optionValues ProductOptionValue[]

  orderItems       OrderItem[]
  stockAdjustments StockAdjustment[]

  @@index([sku])
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  E_WALLET
  BANK_TRANSFER
}

enum AdjustmentReason {
  DAMAGED
  LOST
  FOUND
  SUPPLIER_RETURN
  MANUAL_COUNT
  OTHER
}

model Order {
  id            String         @id @default(cuid())
  total         Decimal
  status        OrderStatus    @default(COMPLETED)
  paymentMethod PaymentMethod?
  cashTendered  Decimal?
  change        Decimal?
  customerName  String?
  notes         String?
  cashierName   String? // For reporting
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  items         OrderItem[]
  customerId    String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  discountId     String?
  discount       Discount?      @relation(fields: [discountId], references: [id])
  discountAmount Decimal?
  createdAt      DateTime       @default(now())
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  price     Decimal // Snapshot of price at time of sale
}

model StockAdjustment {
  id               String           @id @default(cuid())
  productVariantId String
  variant          ProductVariant   @relation(fields: [productVariantId], references: [id])
  quantity         Int // Positive for increase, negative for decrease
  reason           AdjustmentReason
  notes            String?
  userId           String
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  createdAt        DateTime         @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  email     String?
  address   String?
  points    Int      @default(0)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([phone])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Discount {
  id          String        @id @default(cuid())
  name        String
  code        String?       @unique  // Optional coupon code
  type        DiscountType
  value       Decimal       // Percentage or fixed amount
  minPurchase Decimal?      // Minimum purchase required
  maxDiscount Decimal?      // Max discount for percentage type
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean       @default(true)
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  orders      Order[]       // Track which orders used this discount
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([code])
  @@index([active])
}

// RBAC Models
model UserRole {
  id          String       @id @default(cuid())
  name        String       // e.g., "Admin", "Manager", "Cashier"
  description String?
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  permissions Permission[]
  users       User[]
  isDefault   Boolean      @default(false) // Default role for new users
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id       String             @id @default(cuid())
  action   PermissionAction
  resource PermissionResource
  roleId   String
  role     UserRole           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, action, resource])
  @@index([roleId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  action     String   // e.g., "CREATE", "UPDATE", "DELETE"
  resource   String   // e.g., "Product", "Order", "Customer"
  resourceId String?  // ID of the affected resource
  details    Json?    // Additional context
  ipAddress  String?
  timestamp  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([timestamp])
}
