// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// RBAC Enums
enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
  MANAGE // Full control
}

enum PermissionResource {
  PRODUCTS
  INVENTORY
  ORDERS
  CUSTOMERS
  DISCOUNTS
  CATEGORIES
  ANALYTICS
  USERS
  SETTINGS
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Business Profile
  email   String?
  website String?
  taxId   String?
  taxRate Decimal @default(0)

  // Receipt Settings
  receiptHeader String?
  receiptFooter String?
  showLogo      Boolean @default(true)
  logoUrl       String?

  // POS Settings
  autoPrintReceipt Boolean @default(true)
  soundEffects     Boolean @default(true)
  barcodeScanner   String? // Scanner type/config

  // Localization Settings
  language   String @default("en")
  currency   String @default("IDR")
  timezone   String @default("Asia/Jakarta")
  dateFormat String @default("DD/MM/YYYY")
  timeFormat String @default("24h") // "12h" or "24h"

  // Step 1: Business Information
  businessType String? // "Retail", "Restaurant", "Service", etc.
  industry     String? // Category/industry

  // Step 2: Contact & Location (address, phone, email, website already exist)
  city       String?
  province   String?
  postalCode String?
  country    String? @default("Indonesia")

  // Step 3: Tax & Legal (taxId, taxRate already exist)
  registrationNumber String?
  legalEntityType    String? // "PT", "CV", "UD", "Perorangan", etc.

  // Onboarding Progress
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0) // Track progress for resume later

  // SKU Auto-Generation Settings
  autoGenerateSku Boolean @default(false)
  skuFormat       String  @default("{BUSINESS}/{DATE}/{COUNTER}")
  skuPrefix       String?
  skuCounter      Int     @default(1)

  // Loyalty Program Settings
  pointsPerCurrency    Decimal @default(0) @db.Decimal(10, 4) // Points earned per 1 unit of currency
  pointRedemptionRate  Decimal @default(0) @db.Decimal(10, 4) // Discount per 1 point redeemed
  minimumRedeemPoints  Int     @default(0)  // Minimum points required to redeem

  users            User[]
  roles            UserRole[]
  products         Product[]
  categories       Category[]
  orders           Order[]
  units            Unit[]
  stockAdjustments StockAdjustment[]
  customers        Customer[]
  discounts        Discount[]
  auditLogs        AuditLog[]
  returns          Return[]
  invitations      Invitation[]
  shifts           Shift[]
  expenses         Expense[]
  pettyCashPayouts PettyCashPayout[]
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified Boolean    @default(false)
  name          String     @default("")
  image         String?
  role          String?    // Simple role string: 'owner' | 'manager' | 'cashier'
  roleId        String?
  userRole      UserRole?  @relation(fields: [roleId], references: [id])
  tenantId      String?
  tenant        Tenant?    @relation(fields: [tenantId], references: [id])
  auditLogs     AuditLog[]
  sessions      Session[]
  accounts      Account[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  shifts        Shift[]
  expenses      Expense[]
  pettyCashPayouts PettyCashPayout[]

  @@index([tenantId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      String   @default("cashier")
  token     String   @unique @default(cuid())
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([tenantId])
}

model Unit {
  id           String        @id @default(cuid())
  name         String // e.g. Box
  abbreviation String // e.g. bx
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  productUnits ProductUnit[]
}

model Category {
  id       String  @id @default(cuid())
  name     String
  parentId String? // NULL for root categories
  tenantId String

  // Relations
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, parentId, tenantId]) // Unique name within same parent and tenant
  @@index([tenantId])
  @@index([parentId])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String? // Main product image
  minStock    Int     @default(10)
  categoryId  String?
  tenantId    String

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Base Unit (e.g. Pcs)
  baseUnitId String?
  // Conversions
  units      ProductUnit[]

  options  ProductOption[]
  variants ProductVariant[]

  @@index([name])
}

model ProductUnit {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation(fields: [productId], references: [id])
  unitId           String
  unit             Unit    @relation(fields: [unitId], references: [id])
  conversionFactor Float // e.g. 12 (1 Box = 12 Base Units)
}

model ProductOption {
  id        String               @id @default(cuid())
  name      String // e.g. Size, Color
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]
}

model ProductOptionValue {
  id       String        @id @default(cuid())
  value    String // e.g. S, Red
  optionId String
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  variants ProductVariant[] // Implicit many-to-many or explicit? Implicit is fine for now.
}

model ProductVariant {
  id        String  @id @default(cuid())
  sku       String  @unique
  barcode   String? @unique // Specific barcode for this variant
  price     Decimal
  cost      Decimal @default(0) // Cost price for profit calculation
  imageUrl  String? // Variant-specific image (optional)
  stock     Int     @default(0) // Stock in Base Unit
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // The combination of values that make up this variant
  optionValues ProductOptionValue[]

  orderItems       OrderItem[]
  stockAdjustments StockAdjustment[]
  returnItems      ReturnItem[]

  @@index([sku])
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  E_WALLET
  BANK_TRANSFER
}

enum AdjustmentReason {
  DAMAGED
  LOST
  FOUND
  SUPPLIER_RETURN
  MANUAL_COUNT
  OTHER
}

model Order {
  id            String         @id @default(cuid())
  total         Decimal
  status        OrderStatus    @default(COMPLETED)
  paymentMethod PaymentMethod? // Legacy single-method field (kept for backward compat)
  cashTendered  Decimal?
  change        Decimal?
  customerName  String?
  notes         String?
  cashierName   String? // For reporting
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  items         OrderItem[]
  paymentEntries PaymentEntry[]
  shiftId       String?
  shift         Shift?         @relation(fields: [shiftId], references: [id])
  customerId    String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  discountId     String?
  discount       Discount?      @relation(fields: [discountId], references: [id])
  discountAmount Decimal?
  returns        Return[]
  createdAt      DateTime       @default(now())
}

model PaymentEntry {
  id       String        @id @default(cuid())
  orderId  String
  order    Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method   PaymentMethod
  amount   Decimal
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model Shift {
  id             String      @id @default(cuid())
  status         ShiftStatus @default(OPEN)
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
  openingFloat   Decimal     @default(0)  // Cash in drawer at open
  expectedCash   Decimal?                 // Calculated: float + cash sales
  actualCash     Decimal?                 // Counted by cashier at close
  difference     Decimal?                 // actualCash - expectedCash
  notes          String?
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  orders         Order[]
  pettyCashPayouts PettyCashPayout[]
  createdAt      DateTime    @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

// ─── Petty Cash Payouts ────────────────────────────────────────────────────────

model PettyCashPayout {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(10, 2)
  reason    String
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now())

  @@index([shiftId])
  @@index([tenantId])
}

model OrderItem {
  id           String         @id @default(cuid())
  orderId      String
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId    String
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  quantity     Int
  price        Decimal // Snapshot of price at time of sale
  cost         Decimal @default(0) // Snapshot of cost at time of sale
  itemDiscount Decimal @default(0) // Per-item discount amount
}

model StockAdjustment {
  id               String           @id @default(cuid())
  productVariantId String
  variant          ProductVariant   @relation(fields: [productVariantId], references: [id])
  quantity         Int // Positive for increase, negative for decrease
  reason           AdjustmentReason
  notes            String?
  userId           String
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  createdAt        DateTime         @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  email     String?
  address   String?
  points    Int      @default(0)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  orders    Order[]
  returns   Return[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([phone])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Discount {
  id          String        @id @default(cuid())
  name        String
  code        String?       @unique  // Optional coupon code
  type        DiscountType
  value       Decimal       // Percentage or fixed amount
  minPurchase Decimal?      // Minimum purchase required
  maxDiscount Decimal?      // Max discount for percentage type
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean       @default(true)
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  orders      Order[]       // Track which orders used this discount
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([code])
  @@index([active])
}

// RBAC Models
model UserRole {
  id          String       @id @default(cuid())
  name        String       // e.g., "Admin", "Manager", "Cashier"
  description String?
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  permissions Permission[]
  users       User[]
  isDefault   Boolean      @default(false) // Default role for new users
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id       String             @id @default(cuid())
  action   PermissionAction
  resource PermissionResource
  roleId   String
  role     UserRole           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, action, resource])
  @@index([roleId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  userName   String   // Snapshot of user name at time of action
  
  action     String   // e.g., "CREATE", "UPDATE", "DELETE", "LOGIN", "LOGOUT"
  resource   String   // e.g., "PRODUCT", "ORDER", "USER", "CATEGORY", "SETTINGS"
  resourceId String?  // ID of the affected resource
  
  details    Json?    // Additional context (old values, new values, etc.)
  ipAddress  String?
  userAgent  String?
  
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, resource])
  @@index([tenantId, action])
}

// Returns & Refunds Enums
enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  DUPLICATE_ORDER
  OTHER
}

enum RefundMethod {
  CASH
  STORE_CREDIT
  ORIGINAL_PAYMENT
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model Return {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  
  reason          ReturnReason
  reasonNote      String?
  
  refundMethod    RefundMethod
  refundAmount    Decimal       @db.Decimal(10, 2)
  
  status          ReturnStatus  @default(PENDING)
  
  processedBy     String
  processedByName String
  
  items           ReturnItem[]
  
  createdAt       DateTime      @default(now())
  processedAt     DateTime?
  
  @@index([tenantId, createdAt])
  @@index([tenantId, orderId])
  @@index([tenantId, status])
}

model ReturnItem {
  id              String          @id @default(cuid())
  returnId        String
  return          Return          @relation(fields: [returnId], references: [id], onDelete: Cascade)
  
  orderItemId     String
  variantId       String
  variant         ProductVariant  @relation(fields: [variantId], references: [id])
  
  quantity        Int
  price           Decimal         @db.Decimal(10, 2)
  refundAmount    Decimal         @db.Decimal(10, 2)
  
  restocked       Boolean         @default(false)
  
  @@index([returnId])
  @@index([variantId])
}

// ─── Expense Tracking ──────────────────────────────────────────────────────────

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARIES
  SUPPLIES
  MARKETING
  MAINTENANCE
  TRANSPORT
  FOOD
  TAX
  OTHER
}

model Expense {
  id         String          @id @default(cuid())
  amount     Decimal         @db.Decimal(10, 2)
  category   ExpenseCategory @default(OTHER)
  date       DateTime        @default(now())
  notes      String?
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  String
  user       User            @relation(fields: [createdBy], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([createdBy])
}
